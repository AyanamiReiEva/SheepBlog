# 存储配置
# 可选值: local, jianguoyun
STORAGE_PRIMARY=local

# 坚果云 WebDAV 配置
# 获取坚果云应用密码: https://www.jianguoyun.com/settings/security
JIANGUOYUN_WEBDAV_URL=https://dav.jianguoyun.com/dav/
JIANGUOYUN_USERNAME=your-email@example.com
JIANGUOYUN_PASSWORD=your-app-password
JIANGUOYUN_BASE_PATH=/myblog/posts/
